# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=${DB_USER}
DB_PASSWORD=${DB_PWD}
DB_NAME=novel_writing

# JWT 配置
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRES_IN=7d

# OpenAI 配置（单 Provider 兼容模式）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=${OPENAI_API_KEY}
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# 多 Provider 高级配置（JSON 格式，设置后将覆盖上面的单 Provider 配置）
# 阶段取值：outline(大纲) | characters(人设) | chapters_outline(章节纲要) | write_chapter(写作) | review(审核) | chat(对话) | all(全部)
# 示例：
# OPENAI_PROVIDERS=[{"name":"openai","baseUrl":"https://api.openai.com/v1","apiKey":"${OPENAI_API_KEY}","models":[{"name":"gpt-4o","phases":["all"]}]},{"name":"deepseek","baseUrl":"https://api.deepseek.com/v1","apiKey":"${DEEPSEEK_API_KEY}","models":[{"name":"deepseek-chat","phases":["outline","write_chapter"]}]}]
