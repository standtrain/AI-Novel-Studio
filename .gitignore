.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db
Desktop.ini

# 临时文件
*.tmp
*.temp
tmp/

# 数据库文件
*.sqlite
*.db

# 测试覆盖报告
coverage/
.nyc_output/

