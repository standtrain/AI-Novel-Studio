#!/usr/bin/env bash
# ============================================================
# pre-commit 钩子：敏感信息扫描 & 合规检查
# ============================================================
set -e

RED='\033[0;31m'
YELLOW='\033[0;33m'
GREEN='\033[0;32m'
NC='\033[0m'

EXIT_CODE=0
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo "============================================"
echo "  pre-commit: 敏感信息扫描"
echo "============================================"

# ---------- 1. 禁止提交 .env 文件（.env.example 模板文件除外） ----------
for f in $STAGED_FILES; do
  case "$(basename "$f")" in
    .env.example|*.env.example) ;;
    .env|.env.local|.env.production|credentials.json|*.pem|*.key)
      echo -e "${RED}[错误] 禁止提交敏感配置文件: $f${NC}"
      EXIT_CODE=1
      ;;
  esac
done

# ---------- 2. 检查暂存内容中的敏感信息 ----------
# 收集所有暂存文件的 diff（新增行），排除 .env.example 模板文件
GIT_DIFF=$(git diff --cached --unified=0)

# 通用排除模式：占位符值 + 环境变量引用 + require 引用
EXCLUDE_PATTERN='(your[_\-]|change[_\-]?(me|this|it)|placeholder|xxxx|xxx|example|changeme|process\.env|\$\{|require\()'

# 2a. 检测真实 API Key（排除占位符、环境变量引用）
API_KEY_MATCHES=$(echo "$GIT_DIFF" | grep -E '^\+.*(api[_-]?key|apikey|API_KEY|OPENAI_API_KEY)\s*[=:]\s*["'"'"']?[a-zA-Z0-9_\-\.]{20,}' | grep -viE "$EXCLUDE_PATTERN" || true)
if [ -n "$API_KEY_MATCHES" ]; then
  echo -e "${RED}[错误] 检测到疑似 API Key 明文！${NC}"
  echo "$API_KEY_MATCHES"
  EXIT_CODE=1
fi

# 2b. 检测真实 JWT Secret（排除占位符、环境变量引用、require）
JWT_MATCHES=$(echo "$GIT_DIFF" | grep -E '^\+.*(JWT_SECRET|jwt[_-]?secret)\s*[=:]\s*["'"'"']?[a-zA-Z0-9_\-\.]{8,}' | grep -viE "$EXCLUDE_PATTERN" || true)
if [ -n "$JWT_MATCHES" ]; then
  echo -e "${RED}[错误] 检测到疑似 JWT_SECRET 明文！${NC}"
  EXIT_CODE=1
fi

# 2c. 检测真实数据库密码（排除占位符、环境变量引用）
DB_PWD_MATCHES=$(echo "$GIT_DIFF" | grep -E '^\+.*(DB_PASSWORD|db_password|MYSQL_PASSWORD)\s*[=:]\s*["'"'"'][^$]{1,}' | grep -viE "$EXCLUDE_PATTERN" || true)
if [ -n "$DB_PWD_MATCHES" ]; then
  echo -e "${RED}[错误] 检测到疑似数据库密码明文！${NC}"
  EXIT_CODE=1
fi

# 2d. 检测 AccessKey / SecretKey
if echo "$GIT_DIFF" | grep -qiE '^\+.*(access[_-]?key[_-]?id|secret[_-]?access[_-]?key|AKIA[A-Z0-9]{16})'; then
  echo -e "${RED}[错误] 检测到疑似云服务 AccessKey！${NC}"
  EXIT_CODE=1
fi

# 2e. 检测私钥
if echo "$GIT_DIFF" | grep -qE '^\+.*-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----'; then
  echo -e "${RED}[错误] 检测到私钥内容！${NC}"
  EXIT_CODE=1
fi

# 2f. 检测内网 IP 地址
if echo "$GIT_DIFF" | grep -qE '^\+.*\b(192\.168\.|10\.\d{1,3}\.|172\.(1[6-9]|2\d|3[01])\.)'; then
  echo -e "${YELLOW}[警告] 检测到内网 IP 地址，请确认是否属于脱敏范围${NC}"
fi

# ---------- 3. 检查大文件（>100MB） ----------
for f in $STAGED_FILES; do
  if [ -f "$f" ]; then
    SIZE=$(wc -c < "$f" 2>/dev/null || echo 0)
    if [ "$SIZE" -gt 104857600 ]; then
      echo -e "${YELLOW}[警告] 文件 $f 超过 100MB ($((SIZE / 1048576))MB)，请确认是否属于必要源码${NC}"
    fi
  fi
done

# ---------- 4. 尝试运行 Gitleaks（如果已安装） ----------
if command -v gitleaks &> /dev/null; then
  echo -e "${GREEN}Gitleaks 检测中...${NC}"
  if ! gitleaks detect --staged --no-banner --verbose 2>/dev/null; then
    echo -e "${RED}[错误] Gitleaks 扫描未通过！${NC}"
    EXIT_CODE=1
  fi
else
  echo -e "${YELLOW}[提示] 未安装 Gitleaks，跳过深度扫描。安装方法：https://github.com/gitleaks/gitleaks${NC}"
fi

echo "============================================"
if [ "$EXIT_CODE" -eq 0 ]; then
  echo -e "${GREEN}  预提交检查通过${NC}"
else
  echo -e "${RED}  预提交检查未通过，请修复后重试${NC}"
fi
echo "============================================"

exit $EXIT_CODE
